        {
          "name": "1.Create Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status Code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "    });",
                  "",
                  "    const response = pm.response.json();",
                  "",
                  "    pm.environment.set(\"employeeId\", response.id);",
                  "",
                  "    pm.test(\"Employee ID Generated\", function () {",
                  "        pm.expect(response.id).to.not.be.null;",
                  "        });",
                  "",
                  "        pm.test(\"Employee Name Matches\", function () {",
                  "            pm.expect(response.employeeName).to.eql(\"John Doe\");",
                  "            });",
                  "",
                  "            pm.test(\"Response Time\", function () {",
                  "                pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "                });"
                ],
